@page "/"
@inject Polyhydra.Ffmpeg.Host.Services.HostWorkflowService Workflow

<MudText Typo="Typo.h3" GutterBottom="true">Dashboard</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
    Live operator snapshot backed by the host's in-memory state and core FFmpeg abstractions.
</MudText>

<MudGrid Spacing="3">
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.overline">Jobs</MudText>
            <MudText Typo="Typo.h4">@Workflow.Overview.JobCount</MudText>
            <MudText Color="Color.Secondary">Queued definitions in memory</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.overline">Probes</MudText>
            <MudText Typo="Typo.h4">Ready</MudText>
            <MudText Color="Color.Secondary">Core probe service is registered</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.overline">Presets</MudText>
            <MudText Typo="Typo.h4">@Workflow.Overview.PresetCount</MudText>
            <MudText Color="Color.Secondary">Seeded encoder templates</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.overline">Failed jobs</MudText>
            <MudText Typo="Typo.h4">@Workflow.Overview.FailedJobs</MudText>
            <MudText Color="Color.Secondary">Tracked in-memory failures</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.overline">Status</MudText>
            <MudText Typo="Typo.h4">Online</MudText>
            <MudText Color="Color.Secondary">Host shell + API surface wired</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-6" Elevation="1">
    <MudText Typo="Typo.h6">Recent activity</MudText>
    @foreach (var job in Workflow.Jobs.Take(3))
    {
        <MudText Typo="Typo.body2">@job.Name — @job.Request.InputPath → @job.Request.OutputPath</MudText>
    }
</MudPaper>
