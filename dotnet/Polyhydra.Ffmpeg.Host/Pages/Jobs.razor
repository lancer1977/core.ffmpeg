@page "/jobs"
@inject Polyhydra.Ffmpeg.Host.Services.HostWorkflowService Workflow
@inject Polyhydra.Ffmpeg.Host.Services.JobExecutionService JobExecution

<MudText Typo="Typo.h3" GutterBottom="true">Jobs</MudText>
<MudText Color="Color.Secondary" Class="mb-4">Create a job request and preview the ffmpeg command built from the shared core abstraction.</MudText>

<MudGrid Spacing="3">
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">New job</MudText>
            <MudTextField @bind-Value="_inputPath" Label="Input path" Margin="Margin.Dense" />
            <MudTextField @bind-Value="_outputPath" Label="Output path" Margin="Margin.Dense" Class="mt-3" />
            <MudCheckBox @bind-Value="_useHls" Color="Color.Primary" Class="mt-3">Use HLS output</MudCheckBox>
            @if (_useHls)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">If segment pattern is blank, the host will derive one from the output name.</MudText>
                <MudTextField @bind-Value="_hlsSegmentTime" Label="HLS segment time (seconds)" Margin="Margin.Dense" Class="mt-3" />
                <MudTextField @bind-Value="_hlsPlaylistType" Label="HLS playlist type" Margin="Margin.Dense" Class="mt-3" />
                <MudTextField @bind-Value="_hlsSegmentPattern" Label="HLS segment pattern (optional)" Margin="Margin.Dense" Class="mt-3" />
            }
            <MudSelect T="string" Label="Preset" @bind-Value="_selectedPresetName" Margin="Margin.Dense" Class="mt-3">
                <MudSelectItem T="string" Value=@("None")>None</MudSelectItem>
                @foreach (var preset in Workflow.Presets)
                {
                    <MudSelectItem T="string" Value="@preset.Name">@preset.Name</MudSelectItem>
                }
            </MudSelect>
            <div class="mt-4 d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@Preview">Preview</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@Enqueue">Queue</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Info" OnClick="@RunLatest">Run latest</MudButton>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">Queue</MudText>
            @if (!string.IsNullOrWhiteSpace(_lastRunSummary))
            {
                <MudAlert Severity="Severity.Success" Class="mb-3">@_lastRunSummary</MudAlert>
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">Latest job statuses are live from the shared host state.</MudText>
            <MudTable Items="@Workflow.Jobs" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Job</MudTh>
                    <MudTh>Input</MudTh>
                    <MudTh>Output</MudTh>
                    <MudTh>Preset</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Job">@context.Name</MudTd>
                    <MudTd DataLabel="Input">@context.Request.InputPath</MudTd>
                    <MudTd DataLabel="Output">@context.Request.OutputPath</MudTd>
                    <MudTd DataLabel="Preset">@(context.Request.Encoder?.Name ?? "None")</MudTd>
                    <MudTd DataLabel="Status">@context.Status</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        @if (JobExecution.History.Count > 0)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="1">
                <MudText Typo="Typo.h6">Run history</MudText>
                <MudTable Items="@JobExecution.History" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Job</MudTh>
                        <MudTh>Started</MudTh>
                        <MudTh>Finished</MudTh>
                        <MudTh>Exit</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Job">@context.JobName</MudTd>
                        <MudTd DataLabel="Started">@context.StartedAtUtc</MudTd>
                        <MudTd DataLabel="Finished">@context.FinishedAtUtc</MudTd>
                        <MudTd DataLabel="Exit">@context.ProcessResult.ExitCode</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        @if (_preview is not null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="1">
                <MudText Typo="Typo.h6">Command preview</MudText>
                <MudText Typo="Typo.body2">@_preview.Name</MudText>
                <MudText Typo="Typo.body2">@string.Join(' ', _preview.Command.Arguments.Select(a => a.Contains(' ') ? $"\"{a}\"" : a))</MudText>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    private string _inputPath = "sample.mp4";
    private string _outputPath = "sample-out.mp4";
    private string _selectedPresetName = "None";
    private Polyhydra.Ffmpeg.Host.Services.JobPreview? _preview;
    private string? _lastRunSummary;

    private string _hlsSegmentTime = "4";
    private string _hlsPlaylistType = "event";
    private string _hlsSegmentPattern = string.Empty;
    private bool _useHls;
    private Polyhydra.Ffmpeg.Contracts.EncoderProfile? SelectedPreset => _selectedPresetName == "None" ? null : Workflow.Presets.FirstOrDefault(p => p.Name == _selectedPresetName);

    private void Preview() => _preview = Workflow.CreatePreview(_inputPath, _outputPath, SelectedPreset, _useHls, _hlsSegmentTime, _hlsPlaylistType, _hlsSegmentPattern);

    private void Enqueue()
    {
        Workflow.Enqueue(_inputPath, _outputPath, SelectedPreset);
        _preview = Workflow.CreatePreview(_inputPath, _outputPath, SelectedPreset, _useHls, _hlsSegmentTime, _hlsPlaylistType, _hlsSegmentPattern);
    }

    private async Task RunLatest()
    {
        var result = await JobExecution.RunLatestAsync();
        _lastRunSummary = $"{result.JobName}: exit {result.ProcessResult.ExitCode?.ToString() ?? "n/a"} ({Workflow.Jobs.FirstOrDefault(job => job.Name == result.JobName)?.Status ?? Polyhydra.Ffmpeg.Contracts.JobStatus.Draft})";
        await InvokeAsync(StateHasChanged);
    }
}
