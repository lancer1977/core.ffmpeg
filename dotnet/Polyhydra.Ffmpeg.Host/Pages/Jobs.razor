@page "/jobs"
@inject Polyhydra.Ffmpeg.Host.Services.HostWorkflowService Workflow

<MudText Typo="Typo.h3" GutterBottom="true">Jobs</MudText>
<MudText Color="Color.Secondary" Class="mb-4">Create a job request and preview the ffmpeg command built from the shared core abstraction.</MudText>

<MudGrid Spacing="3">
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">New job</MudText>
            <MudTextField @bind-Value="_inputPath" Label="Input path" Margin="Margin.Dense" />
            <MudTextField @bind-Value="_outputPath" Label="Output path" Margin="Margin.Dense" Class="mt-3" />
            <MudSelect T="string" Label="Preset" @bind-Value="_selectedPresetName" Margin="Margin.Dense" Class="mt-3">
                <MudSelectItem T="string" Value=@("None")>None</MudSelectItem>
                @foreach (var preset in Workflow.Presets)
                {
                    <MudSelectItem T="string" Value="@preset.Name">@preset.Name</MudSelectItem>
                }
            </MudSelect>
            <div class="mt-4 d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@Preview">Preview</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@Enqueue">Queue</MudButton>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">Queue</MudText>
            <MudTable Items="@Workflow.Jobs" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Job</MudTh>
                    <MudTh>Input</MudTh>
                    <MudTh>Output</MudTh>
                    <MudTh>Preset</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Job">@context.Name</MudTd>
                    <MudTd DataLabel="Input">@context.Request.InputPath</MudTd>
                    <MudTd DataLabel="Output">@context.Request.OutputPath</MudTd>
                    <MudTd DataLabel="Preset">@(context.Request.Encoder?.Name ?? "None")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        @if (_preview is not null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="1">
                <MudText Typo="Typo.h6">Command preview</MudText>
                <MudText Typo="Typo.body2">@_preview.Name</MudText>
                <MudText Typo="Typo.body2">@string.Join(' ', _preview.Command.Arguments.Select(a => a.Contains(' ') ? $"\"{a}\"" : a))</MudText>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    private string _inputPath = "sample.mp4";
    private string _outputPath = "sample-out.mp4";
    private string _selectedPresetName = "None";
    private Polyhydra.Ffmpeg.Host.Services.JobPreview? _preview;

    private Polyhydra.Ffmpeg.Contracts.EncoderProfile? SelectedPreset => _selectedPresetName == "None" ? null : Workflow.Presets.FirstOrDefault(p => p.Name == _selectedPresetName);

    private void Preview() => _preview = Workflow.CreatePreview(_inputPath, _outputPath, SelectedPreset);

    private void Enqueue()
    {
        Workflow.Enqueue(_inputPath, _outputPath, SelectedPreset);
        _preview = Workflow.CreatePreview(_inputPath, _outputPath, SelectedPreset);
    }
}
