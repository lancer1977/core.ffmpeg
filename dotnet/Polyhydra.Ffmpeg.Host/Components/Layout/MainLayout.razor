@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Primary" Elevation="1" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.PlayCircleOutline" Class="me-2" />
        <MudText Typo="Typo.h6" Class="app-title">Polyhydra FFmpeg Host</MudText>
        <MudSpacer />
        <MudChip T="string" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small">Operator Shell</MudChip>
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Mini" Elevation="1" ClipMode="DrawerClipMode.Never">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/jobs" Icon="@Icons.Material.Filled.QueuePlayNext">Jobs</MudNavLink>
            <MudNavLink Href="/probe" Icon="@Icons.Material.Filled.Search">Probe</MudNavLink>
            <MudNavLink Href="/presets" Icon="@Icons.Material.Filled.Tune">Presets</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
